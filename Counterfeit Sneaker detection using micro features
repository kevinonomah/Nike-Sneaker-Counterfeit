,"\u001b[1m193/193\u001b[0m \u001b[32mв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ\u001b[0m\u001b[37m\u001b[0m \u001b[1m1s\u001b[0m 3ms/step - accuracy: 0.9696 - loss: 0.1223 - val_accuracy: 0.9585 - val_loss: 0.1635\n","Epoch 50/50\n","\u001b[1m193/193\u001b[0m \u001b[32mв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ\u001b[0m\u001b[37m\u001b[0m \u001b[1m1s\u001b[0m 3ms/step - accuracy: 0.9692 - loss: 0.1216 - val_accuracy: 0.9585 - val_loss: 0.1613\n","\n","Validation metrics:\n","accuracy: 0.9585\n","precision: 0.9583\n","recall: 0.9530\n","f1: 0.9557\n","\n","[Pipeline Complete. Models Saved Successfully.]\n"]}],"source":["import os\n","import gc\n","import cv2\n","import yaml\n","import random\n","import numpy as np\n","import tensorflow as tf\n","from tensorflow.keras import layers, models\n","from sklearn.metrics.pairwise import cosine_distances\n","from sklearn.metrics import accuracy_score, precision_score, recall_score, f1_score\n","from sklearn.model_selection import train_test_split\n","\n","!pip install ultralytics\n","!pip install torch\n","\n","from ultralytics import YOLO\n","\n","# ==============================================================================\n","# CONFIGURATION - DUAL YOLO ARCHITECTURE\n","# ==============================================================================\n","\n","CONFIG = {\n","    \"BASE_DIR\": \"/content/drive/MyDrive/Datasets\",\n","    \"DS1_DIR\": \"Nike Shoes Detection\",\n","    \"DS3_DIR\": \"Real Fake Sneakers\",\n","\n","    # YOLO hyperparameters\n","    \"YOLO_WEIGHTS\": \"yolov8n.pt\",\n","    \"YOLO_IMG_SIZE\": 640,\n","    \"YOLO_EPOCHS\": 50,\n","    \"YOLO_BATCH\": 16,\n","    \"YOLO_CONF\": 0.25,\n","\n","    # Siamese hyperparameters\n","    \"CROP_SIZE\": (128, 128),\n","    \"EMBED_DIM\": 128,\n","    \"SIAMESE_EPOCHS\": 30,\n","    \"SIAMESE_BATCH\": 32,\n","    \"SIAMESE_MARGIN\": 1.0,\n","    \"MAX_PAIRS_PER_CLASS\": 2000,\n","    \"MAX_REF_PER_CLASS\": 200,\n","\n","    # Fusion MLP hyperparameters\n","    \"MLP_EPOCHS\": 50,\n","    \"MLP_BATCH\": 16,\n","\n","    # Misc\n","    \"RANDOM_SEED\": 42\n","}\n","\n","CONFIG[\"DS1_ROOT\"] = os.path.join(CONFIG[\"BASE_DIR\"], CONFIG[\"DS1_DIR\"])\n","CONFIG[\"DS3_ROOT\"] = os.path.join(CONFIG[\"BASE_DIR\"], CONFIG[\"DS3_DIR\"])\n","CONFIG[\"DS1_YAML\"] = os.path.join(CONFIG[\"DS1_ROOT\"], \"data.yaml\")\n","CONFIG[\"DS3_YAML\"] = os.path.join(CONFIG[\"DS3_ROOT\"], \"data.yaml\")\n","\n","# Map DS1 (4-class) detection to binary authenticity\n","CONFIG[\"DS1_BINARY_MAP\"] = {\n","    0: 0,  # fake\n","    1: 0,  # fake\n","    2: 1,  # original\n","    3: 1   # original\n","}\n","\n","tf.keras.backend.clear_session()\n","gc.collect()\n","np.random.seed(CONFIG[\"RANDOM_SEED\"])\n","tf.random.set_seed(CONFIG[\"RANDOM_SEED\"])\n","random.seed(CONFIG[\"RANDOM_SEED\"])\n","\n","# ==============================================================================\n","# BASIC UTILITIES\n","# ==============================================================================\n","\n","def load_yaml(path):\n","    with open(path, \"r\") as f: return yaml.safe_load(f)\n","\n","def safe_read_rgb(img_path):\n","    img = cv2.imread(img_path)\n","    if img is None: return None\n","    return cv2.cvtColor(img, cv2.COLOR_BGR2RGB)\n","\n","def resize_norm(img, size):\n","    if img is None or img.size == 0: return np.zeros(size + (3,), dtype=np.float32)\n","    return cv2.resize(img, size).astype(np.float32) / 255.0\n","\n","def list_images(folder):\n","    exts = (\".jpg\", \".jpeg\", \".png\", \".bmp\", \".webp\")\n","    files = []\n","    if not os.path.exists(folder): return files\n","    for root, _, names in os.walk(folder):\n","        for n in names:\n","            if n.lower().endswith(exts): files.append(os.path.join(root, n))\n","    return sorted(files)\n","\n","def get_split_paths(dataset_root, split):\n","    return os.path.join(dataset_root, split, \"images\"), os.path.join(dataset_root, split, \"labels\")\n","\n","def safe_metrics(y_true, y_pred):\n","    return {\n","        \"accuracy\": accuracy_score(y_true, y_pred),\n","        \"precision\": precision_score(y_true, y_pred, zero_division=0),\n","        \"recall\": recall_score(y_true, y_pred, zero_division=0),\n","        \"f1\": f1_score(y_true, y_pred, zero_division=0),\n","    }\n","\n","# ==============================================================================\n","# YOLO LABEL PARSING (FOR DS3 GROUND TRUTH EXTRACT)\n","# ==============================================================================\n","\n","def read_yolo_annotations(label_path, img_w, img_h):\n","    anns = []\n","    if not os.path.exists(label_path): return anns\n","    with open(label_path, \"r\") as f:\n","        for line in f:\n","            parts = line.strip().split()\n","            if len(parts) == 5:\n","                cls_id, x_c, y_c, bw, bh = map(float, parts)\n","                x1 = int(max(0, (x_c - bw / 2) * img_w))\n","                y1 = int(max(0, (y_c - bh / 2) * img_h))\n","                x2 = int(min(img_w, (x_c + bw / 2) * img_w))\n","                y2 = int(min(img_h, (y_c + bh / 2) * img_h))\n","                if x2 > x1 and y2 > y1: anns.append((int(cls_id), x1, y1, x2, y2))\n","    return anns\n","\n","# ==============================================================================\n","# STAGE 1 & 1.5: DUAL YOLO DETECTORS\n","# ==============================================================================\n","\n","def train_yolo_model(yaml_path, project_name):\n","    print(f\"\\n--- Training YOLO Model: {project_name} ---\")\n","    model = YOLO(CONFIG[\"YOLO_WEIGHTS\"])\n","    model.train(\n","        data=yaml_path, epochs=CONFIG[\"YOLO_EPOCHS\"], imgsz=CONFIG[\"YOLO_IMG_SIZE\"],\n","        batch=CONFIG[\"YOLO_BATCH\"], project=os.path.join(CONFIG[\"BASE_DIR\"], \"runs\", \"detect\"),\n","        name=project_name\n","    )\n","    return model\n","\n","def get_best_shoe_prediction(model, img_path, conf=CONFIG[\"YOLO_CONF\"]):\n","    results = model(img_path, conf=conf, verbose=False)[0]\n","    if results.boxes is None or len(results.boxes) == 0: return None\n","\n","    confs = results.boxes.conf.cpu().numpy()\n","    boxes = results.boxes.xyxy.cpu().numpy()\n","    clss = results.boxes.cls.cpu().numpy().astype(int)\n","\n","    best_idx = int(np.argmax(confs))\n","    return {\n","        \"box\": boxes[best_idx],\n","        \"det_conf\": float(confs[best_idx]),\n","        \"ds1_class\": int(clss[best_idx]),\n","        \"binary_auth_label\": CONFIG[\"DS1_BINARY_MAP\"].get(int(clss[best_idx]), 0)\n","    }\n","\n","def crop_box(img, box):\n","    if box is None: return None\n","    h, w = img.shape[:2]\n","    x1, y1, x2, y2 = map(int, box)\n","    x1, y1, x2, y2 = max(0, x1), max(0, y1), min(w, x2), min(h, y2)\n","    if x2 <= x1 or y2 <= y1: return None\n","    return img[y1:y2, x1:x2]\n","\n","def extract_microregions_with_yolo(shoe_crop, yolo_micro):\n","    \"\"\"DYNAMIC EXTRACTION: Uses DS3 YOLO to find logo/stitch inside the shoe crop.\"\"\"\n","    if shoe_crop is None or shoe_crop.size == 0:\n","        z = np.zeros(CONFIG[\"CROP_SIZE\"] + (3,), dtype=np.float32)\n","        return z, z\n","\n","    results = yolo_micro(shoe_crop, verbose=False)[0]\n","    logo_box, stitch_box = None, None\n","    max_logo_conf, max_stitch_conf = -1, -1\n","\n","    if results.boxes is not None and len(results.boxes) > 0:\n","        confs = results.boxes.conf.cpu().numpy()\n","        boxes = results.boxes.xyxy.cpu().numpy()\n","        clss = results.boxes.cls.cpu().numpy().astype(int)\n","\n","        # DS3 YAML standard: 0 = ShoeLogo, 1 = StitchingPatterns\n","        for i, c in enumerate(clss):\n","            if c == 0 and confs[i] > max_logo_conf:\n","                logo_box, max_logo_conf = boxes[i], confs[i]\n","            elif c == 1 and confs[i] > max_stitch_conf:\n","                stitch_box, max_stitch_conf = boxes[i], confs[i]\n","\n","    logo_img = resize_norm(crop_box(shoe_crop, logo_box), CONFIG[\"CROP_SIZE\"]) if logo_box is not None else np.zeros(CONFIG[\"CROP_SIZE\"] + (3,), dtype=np.float32)\n","    stitch_img = resize_norm(crop_box(shoe_crop, stitch_box), CONFIG[\"CROP_SIZE\"]) if stitch_box is not None else np.zeros(CONFIG[\"CROP_SIZE\"] + (3,), dtype=np.float32)\n","\n","    return logo_img, stitch_img\n","\n","# ==============================================================================\n","# STAGE 2: SIAMESE EMBEDDING MODEL & REFERENCE BANK (Trained on DS3 GT)\n","# ==============================================================================\n","\n","def build_embedding_tower(input_shape=CONFIG[\"CROP_SIZE\"] + (3,), emb_dim=CONFIG[\"EMBED_DIM\"]):\n","    inp = layers.Input(shape=input_shape)\n","    x = layers.Conv2D(32, 3, padding=\"same\", activation=\"relu\")(inp)\n","    x = layers.MaxPooling2D()(x)\n","    x = layers.Conv2D(64, 3, padding=\"same\", activation=\"relu\")(x)\n","    x = layers.MaxPooling2D()(x)\n","    x = layers.Conv2D(128, 3, padding=\"same\", activation=\"relu\")(x)\n","    x = layers.GlobalAveragePooling2D()(x)\n","    x = layers.Dense(emb_dim)(x)\n","    out = layers.UnitNormalization()(x)\n","    return models.Model(inp, out, name=\"embedding_tower\")\n","\n","def euclidean_distance(vects):\n","    return tf.sqrt(tf.maximum(tf.reduce_sum(tf.square(vects[0] - vects[1]), axis=1, keepdims=True), 1e-12))\n","\n","def contrastive_loss(margin=CONFIG[\"SIAMESE_MARGIN\"]):\n","    def loss(y_true, y_pred):\n","        y_true = tf.cast(y_true, y_pred.dtype)\n","        return tf.reduce_mean((1 - y_true) * tf.square(y_pred) + y_true * tf.square(tf.maximum(margin - y_pred, 0)))\n","    return loss\n","\n","def extract_ds3_ground_truth_crops(ds3_root=CONFIG[\"DS3_ROOT\"], ds3_yaml_path=CONFIG[\"DS3_YAML\"]):\n","    \"\"\"Extracts perfect crops using the human-labeled ground truth files in DS3 for Siamese training.\"\"\"\n","    class_names = load_yaml(ds3_yaml_path).get(\"names\", {0: 'ShoeLogo', 1: 'StitchingPatterns'})\n","    if isinstance(class_names, dict): class_names = list(class_names.values())\n","    crops_dict = {name: [] for name in class_names}\n","\n","    for split in [\"train\", \"valid\", \"test\"]:\n","        img_dir, lbl_dir = get_split_paths(ds3_root, split)\n","        for img_path in list_images(img_dir):\n","            label_path = os.path.join(lbl_dir, os.path.splitext(os.path.basename(img_path))[0] + \".txt\")\n","            img = safe_read_rgb(img_path)\n","            if img is None: continue\n","\n","            anns = read_yolo_annotations(label_path, img.shape[1], img.shape[0])\n","            for cls_id, x1, y1, x2, y2 in anns:\n","                if cls_id < len(class_names):\n","                    crop = img[y1:y2, x1:x2]\n","                    if crop.size > 0: crops_dict[class_names[cls_id]].append(crop)\n","    return crops_dict\n","\n","def make_crop_pairs(crops_dict, max_pairs=CONFIG[\"MAX_PAIRS_PER_CLASS\"]):\n","    rng = np.random.default_rng(CONFIG[\"RANDOM_SEED\"])\n","    pair_a, pair_b, labels = [], [], []\n","    classes = list(crops_dict.keys())\n","\n","    for c in classes:\n","        crops = crops_dict[c]\n","        if len(crops) < 2: continue\n","        for _ in range(min(max_pairs, len(crops) * 2)):\n","            i, j = rng.choice(len(crops), size=2, replace=False)\n","            pair_a.append(resize_norm(crops[i], CONFIG[\"CROP_SIZE\"]))\n","            pair_b.append(resize_norm(crops[j], CONFIG[\"CROP_SIZE\"]))\n","            labels.append(0.0)\n","\n","    if len(classes) >= 2:\n","        cA, cB = crops_dict[classes[0]], crops_dict[classes[1]]\n","        if len(cA) > 0 and len(cB) > 0:\n","            for _ in range(min(max_pairs, len(cA), len(cB))):\n","                pair_a.append(resize_norm(cA[rng.integers(0, len(cA))], CONFIG[\"CROP_SIZE\"]))\n","                pair_b.append(resize_norm(cB[rng.integers(0, len(cB))], CONFIG[\"CROP_SIZE\"]))\n","                labels.append(1.0)\n","\n","    return np.array(pair_a, dtype=np.float32), np.array(pair_b, dtype=np.float32), np.array(labels, dtype=np.float32)\n","\n","def train_siamese_on_ds3(siamese_model, crops_dict):\n","    print(\"\\n--- Training Siamese on DS3 ---\")\n","    xa, xb, y = make_crop_pairs(crops_dict)\n","    siamese_model.fit([xa, xb], y, batch_size=CONFIG[\"SIAMESE_BATCH\"], epochs=CONFIG[\"SIAMESE_EPOCHS\"], verbose=1)\n","    return siamese_model\n","\n","def build_reference_bank_ds3(tower, crops_dict, max_refs=CONFIG[\"MAX_REF_PER_CLASS\"]):\n","    bank = {}\n","    for feature, crops in crops_dict.items():\n","        keep = crops[:max_refs]\n","        if not keep: continue\n","        bank[feature] = tower.predict(np.array([resize_norm(c, CONFIG[\"CROP_SIZE\"]) for c in keep]), verbose=0)\n","    return bank\n","\n","# ==============================================================================\n","# STAGE 3: FUSION PREP (DS1)\n","# ==============================================================================\n","\n","def get_gt_binary_label(label_path):\n","    if not os.path.exists(label_path): return None\n","    with open(label_path, \"r\") as f:\n","        lines = [ln.strip() for ln in f.readlines() if ln.strip()]\n","    if not lines: return None\n","\n","    cls_ids = [int(float(line.split()[0])) for line in lines]\n","    mapped = [CONFIG[\"DS1_BINARY_MAP\"][cid] for cid in cls_ids if cid in CONFIG[\"DS1_BINARY_MAP\"]]\n","    if not mapped: return None\n","    values, counts = np.unique(mapped, return_counts=True)\n","    return int(values[np.argmax(counts)])\n","\n","def collect_ds1_samples(ds1_root=CONFIG[\"DS1_ROOT\"]):\n","    img_paths, labels = [], []\n","    for split in [\"train\", \"valid\", \"test\"]:\n","        img_dir, lbl_dir = get_split_paths(ds1_root, split)\n","        for img_path in list_images(img_dir):\n","            label_path = os.path.join(lbl_dir, os.path.splitext(os.path.basename(img_path))[0] + \".txt\")\n","            y = get_gt_binary_label(label_path)\n","            if y is not None:\n","                img_paths.append(img_path)\n","                labels.append(y)\n","    return img_paths, np.array(labels, dtype=np.int32)\n","\n","def compute_stats(emb, bank_embs):\n","    if bank_embs is None or len(bank_embs) == 0: return [1.0, 1.0]\n","    dists = cosine_distances([emb], bank_embs)[0]\n","    return [float(np.min(dists)), float(np.mean(dists))]\n","\n","def build_feature_vector(img_path, yolo_shoe, yolo_micro, tower, ref_bank):\n","    img = safe_read_rgb(img_path)\n","    if img is None: return None\n","\n","    # 1. Use DS1 YOLO to find the shoe\n","    pred_shoe = get_best_shoe_prediction(yolo_shoe, img_path)\n","    if pred_shoe is None: return None\n","    shoe_crop = crop_box(img, pred_shoe[\"box\"])\n","\n","    # 2. Use DS3 YOLO to find logo/stitch inside the shoe crop\n","    logo_img, stitch_img = extract_microregions_with_yolo(shoe_crop, yolo_micro)\n","\n","    # 3. Generate Siamese Embeddings\n","    logo_emb = tower.predict(np.expand_dims(logo_img, axis=0), verbose=0)[0]\n","    stitch_emb = tower.predict(np.expand_dims(stitch_img, axis=0), verbose=0)[0]\n","\n","    logo_stats = compute_stats(logo_emb, ref_bank.get(\"ShoeLogo\", []))\n","    stitch_stats = compute_stats(stitch_emb, ref_bank.get(\"StitchingPatterns\", []))\n","\n","    # Calculate shoe vs image ratios\n","    shoe_h, shoe_w = shoe_crop.shape[:2] if shoe_crop is not None else (1, 1)\n","    img_h, img_w = img.shape[:2]\n","\n","    pred_one_hot = np.zeros(4, dtype=np.float32)\n","    if 0 <= pred_shoe[\"ds1_class\"] < 4: pred_one_hot[pred_shoe[\"ds1_class\"]] = 1.0\n","\n","    return np.concatenate([\n","        np.array(logo_stats + stitch_stats, dtype=np.float32),                                      # 4 (Distances)\n","        np.array([pred_shoe[\"det_conf\"], (shoe_h*shoe_w)/(img_h*img_w), shoe_w/shoe_h], dtype=np.float32), # 3 (Stats)\n","        pred_one_hot,                                                                               # 4 (Shoe Probs)\n","        logo_emb.astype(np.float32),                                                                # 128\n","        stitch_emb.astype(np.float32)                                                               # 128\n","    ])\n","\n","def build_dataset_features(img_paths, labels, yolo_shoe, yolo_micro, tower, reference_bank):\n","    X, y = [], []\n","    for i, path in enumerate(img_paths):\n","        fvec = build_feature_vector(path, yolo_shoe, yolo_micro, tower, reference_bank)\n","        if fvec is not None:\n","            X.append(fvec)\n","            y.append(labels[i])\n","    if not X: return np.empty((0, 267), dtype=np.float32), np.array([])\n","    return np.array(X, dtype=np.float32), np.array(y, dtype=np.int32)\n","\n","# ==============================================================================\n","# STAGE 4: FUSION MLP\n","# ==============================================================================\n","\n","def train_auth_classifier(X_train, y_train, X_val, y_val):\n","    print(\"\\n--- Training Fusion MLP ---\")\n","    model = models.Sequential([\n","        layers.Input(shape=(X_train.shape[1],)),\n","        layers.Dense(128, activation=\"relu\"),\n","        layers.Dropout(0.3),\n","        layers.Dense(64, activation=\"relu\"),\n","        layers.Dense(1, activation=\"sigmoid\")\n","    ])\n","    model.compile(optimizer=\"adam\", loss=\"binary_crossentropy\", metrics=[\"accuracy\"])\n","    model.fit(X_train, y_train, validation_data=(X_val, y_val), epochs=CONFIG[\"MLP_EPOCHS\"], batch_size=CONFIG[\"MLP_BATCH\"], verbose=1)\n","\n","    y_pred = (model.predict(X_val, verbose=0).ravel() >= 0.5).astype(int)\n","    scores = safe_metrics(y_val, y_pred)\n","    print(\"\\nValidation metrics:\"); [print(f\"{k}: {v:.4f}\") for k, v in scores.items()]\n","    return model\n","\n","# ==============================================================================\n","# MAIN EXECUTION SCRIPT\n","# ==============================================================================\n","\n","if __name__ == \"__main__\":\n","    print(\"BASE_DIR:\", CONFIG[\"BASE_DIR\"])\n","\n","    # 1. Train DS1 YOLO (Whole Shoe Detection)\n","    print(\"\\n[Executing Stage 1: Training YOLO for Whole Shoes (DS1)]\")\n","    yolo_shoe = train_yolo_model(CONFIG[\"DS1_YAML\"], \"ds1_shoe_detector\")\n","\n","    # 2. Train DS3 YOLO (Micro-Feature Detection)\n","    print(\"\\n[Executing Stage 1.5: Training YOLO for Micro-Features (DS3)]\")\n","    yolo_micro = train_yolo_model(CONFIG[\"DS3_YAML\"], \"ds3_micro_detector\")\n","\n","    # 3. Train Siamese Network on precise DS3 Ground Truth Crops\n","    print(\"\\n[Executing Stage 2: Extracting DS3 Crops & Training Siamese]\")\n","    ds3_crops = extract_ds3_ground_truth_crops()\n","    tower = build_embedding_tower()\n","\n","    # Needs a siamese wrapper to train contrastive loss\n","    inp_a = layers.Input(shape=CONFIG[\"CROP_SIZE\"] + (3,))\n","    inp_b = layers.Input(shape=CONFIG[\"CROP_SIZE\"] + (3,))\n","    dist = layers.Lambda(euclidean_distance)([tower(inp_a), tower(inp_b)])\n","    siamese_model = models.Model([inp_a, inp_b], dist)\n","    siamese_model.compile(optimizer=\"adam\", loss=contrastive_loss())\n","\n","    train_siamese_on_ds3(siamese_model, ds3_crops)\n","    tower.trainable = False\n","\n","    # 4. Build reference bank\n","    print(\"\\n[Building Reference Bank]\")\n","    reference_bank = build_reference_bank_ds3(tower, ds3_crops)\n","\n","    # 5. Extract Fused Features using Dual-YOLO + Siamese\n","    print(\"\\n[Executing Stage 3: Dynamic Feature Extraction on DS1]\")\n","    img_paths, labels = collect_ds1_samples()\n","    X_train_paths, X_val_paths, y_train_lbls, y_val_lbls = train_test_split(img_paths, labels, test_size=0.2, random_state=CONFIG[\"RANDOM_SEED\"], stratify=labels)\n","\n","    X_train, y_train = build_dataset_features(X_train_paths, y_train_lbls, yolo_shoe, yolo_micro, tower, reference_bank)\n","    X_val, y_val = build_dataset_features(X_val_paths, y_val_lbls, yolo_shoe, yolo_micro, tower, reference_bank)\n","\n","    print(\"X_train fused shape:\", X_train.shape)\n","\n","    # 6. Train Fusion Classifier (MLP)\n","    print(\"\\n[Executing Stage 4: MLP Training]\")\n","    mlp_model = train_auth_classifier(X_train, y_train, X_val, y_val)\n","\n","    # Save the models\n","    tower.save(os.path.join(CONFIG[\"BASE_DIR\"], \"siamese_tower.keras\"))\n","    mlp_model.save(os.path.join(CONFIG[\"BASE_DIR\"], \"fusion_mlp.keras\"))\n","\n","    print(\"\\n[Pipeline Complete. Models Saved Successfully.]\")"]},{"cell_type":"code","source":["# ==============================================================================\n","# CELL 10: THESIS VISUALS (ROC Curve & Confusion Matrix)\n","# ==============================================================================\n","import matplotlib.pyplot as plt\n","import seaborn as sns\n","from sklearn.metrics import confusion_matrix, roc_curve, auc\n","\n","def generate_thesis_visuals(mlp_model, X_val, y_val):\n","    print(\"\\n[Generating Publication-Ready Visuals]\")\n","\n","    # Get predictions and probabilities\n","    y_prob = mlp_model.predict(X_val, verbose=0).ravel()\n","    y_pred = (y_prob >= 0.5).astype(int)\n","\n","    # 1. Plot Confusion Matrix\n","    cm = confusion_matrix(y_val, y_pred)\n","    plt.figure(figsize=(6, 5))\n","    sns.heatmap(cm, annot=True, fmt='d', cmap='Blues',\n","                xticklabels=['Fake (0)', 'Original (1)'],\n","                yticklabels=['Fake (0)', 'Original (1)'])\n","    plt.title('Fusion MLP Confusion Matrix')\n","    plt.ylabel('True Authenticity')\n","    plt.xlabel('Predicted Authenticity')\n","    plt.tight_layout()\n","    plt.savefig(os.path.join(CONFIG[\"BASE_DIR\"], \"confusion_matrix.png\"), dpi=300)\n","    plt.show()\n","\n","    # 2. Plot ROC Curve\n","    fpr, tpr, thresholds = roc_curve(y_val, y_prob)\n","    roc_auc = auc(fpr, tpr)\n","\n","    plt.figure(figsize=(6, 5))\n","    plt.plot(fpr, tpr, color='darkorange', lw=2, label=f'ROC curve (AUC = {roc_auc:.4f})')\n","    plt.plot([0, 1], [0, 1], color='navy', lw=2, linestyle='--')\n","    plt.xlim([0.0, 1.0])\n","    plt.ylim([0.0, 1.05])\n","    plt.xlabel('False Positive Rate')\n","    plt.ylabel('True Positive Rate')\n","    plt.title('Receiver Operating Characteristic (ROC)')\n","    plt.legend(loc=\"lower right\")\n","    plt.tight_layout()\n","    plt.savefig(os.path.join(CONFIG[\"BASE_DIR\"], \"roc_curve.png\"), dpi=300)\n","    plt.show()\n","\n","    print(\"Visuals saved to your Drive.\")\n","\n","# Execute\n","generate_thesis_visuals(mlp_model, X_val, y_val)"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":1000},"id":"3EzVCFT0Tu3G","executionInfo":{"status":"ok","timestamp":1774299299960,"user_tz":300,"elapsed":1513,"user":{"displayName":"Kevin Osei-Onomah","userId":"07800293995269467633"}},"outputId":"85c4db7c-5115-4888-86ba-73c8f9674576"},"execution_count":3,"outputs":[{"output_type":"stream","name":"stdout","text":["\n","[Generating Publication-Ready Visuals]\n"]},{"output_type":"display_data","data":{"text/plain":["<Figure size 600x500 with 2 Axes>"],"image/png":"\n"},"metadata":{}},{"output_type":"display_data","data":{"text/plain":["<Figure size 600x500 with 1 Axes>"],"image/png":"\n"},"metadata":{}},{"output_type":"stream","name":"stdout","text":["Visuals saved to your Drive.\n"]}]},{"cell_type":"code","source":["# ==============================================================================\n","# CELL 11: OPTIMIZED LATENCY BENCHMARKING\n","# ==============================================================================\n","import time\n","import numpy as np\n","\n","def compute_stats_fast(emb, bank_embs):\n","    \"\"\"Ultra-fast Cosine Distance using pure NumPy (assumes L2 normalized vectors)\"\"\"\n","    if bank_embs is None or len(bank_embs) == 0: return [1.0, 1.0]\n","    # Cosine Distance = 1 - Cosine Similarity (Dot Product of normalized vectors)\n","    sims = np.dot(bank_embs, emb)\n","    dists = 1.0 - sims\n","    return [float(np.min(dists)), float(np.mean(dists))]\n","\n","def benchmark_latency_optimized(img_paths, yolo_shoe, yolo_micro, tower, mlp_model, ref_bank, num_samples=100):\n","    print(f\"\\n[Benchmarking OPTIMIZED Latency on {num_samples} images]\")\n","    test_paths = np.random.choice(img_paths, min(num_samples, len(img_paths)), replace=False)\n","    execution_times = []\n","\n","    # Warm-up the GPU with direct tensor calls\n","    dummy_img = np.zeros((1, 128, 128, 3), dtype=np.float32)\n","    _ = tower(dummy_img, training=False)\n","    _ = mlp_model(np.zeros((1, 267), dtype=np.float32), training=False)\n","\n","    for path in test_paths:\n","        start_time = time.perf_counter()\n","\n","        # 1. Whole Shoe YOLO\n","        pred_shoe = get_best_shoe_prediction(yolo_shoe, path, conf=0.25)\n","        if pred_shoe is not None:\n","            img = safe_read_rgb(path)\n","            shoe_crop = crop_box(img, pred_shoe[\"box\"])\n","\n","            # 2. Micro YOLO\n","            logo_img, stitch_img = extract_microregions_with_yolo(shoe_crop, yolo_micro)\n","\n","            # 3. Siamese Embeddings (BATCHED & OPTIMIZED)\n","            # We stack both images into a single batch to halve the inference time\n","            batch_imgs = np.stack([logo_img, stitch_img])\n","            embeddings = tower(batch_imgs, training=False).numpy() # Direct tensor call!\n","            logo_emb, stitch_emb = embeddings[0], embeddings[1]\n","\n","            # 4. Fast Distance Math\n","            l_stats = compute_stats_fast(logo_emb, ref_bank.get(\"ShoeLogo\", []))\n","            s_stats = compute_stats_fast(stitch_emb, ref_bank.get(\"StitchingPatterns\", []))\n","\n","            shoe_h, shoe_w = shoe_crop.shape[:2] if shoe_crop is not None else (1, 1)\n","            img_h, img_w = img.shape[:2]\n","\n","            pred_one_hot = np.zeros(4, dtype=np.float32)\n","            if 0 <= pred_shoe[\"ds1_class\"] < 4: pred_one_hot[pred_shoe[\"ds1_class\"]] = 1.0\n","\n","            fvec = np.concatenate([\n","                np.array(l_stats + s_stats, dtype=np.float32),\n","                np.array([pred_shoe[\"det_conf\"], (shoe_h*shoe_w)/max(img_h*img_w, 1), shoe_w/max(shoe_h, 1)], dtype=np.float32),\n","                pred_one_hot,\n","                logo_emb, stitch_emb\n","            ])\n","\n","            # 5. MLP Prediction (OPTIMIZED)\n","            _ = mlp_model(np.expand_dims(fvec, axis=0), training=False).numpy() # Direct tensor call!\n","\n","        end_time = time.perf_counter()\n","        execution_times.append((end_time - start_time) * 1000) # ms\n","\n","    avg_latency = np.mean(execution_times)\n","    p95_latency = np.percentile(execution_times, 95)\n","\n","    print(f\"Average Latency: {avg_latency:.2f} ms per image\")\n","    print(f\"95th Percentile: {p95_latency:.2f} ms per image\")\n","\n","    if avg_latency <= 50.0:\n","        print(\"вњ… SUCCESS: Model meets the <= 50ms efficiency threshold.\")\n","    else:\n","        print(\"вљ пёЏ WARNING: Still exceeding 50ms. Further edge-optimization required.\")\n","\n","# Execute with optimizations\n","benchmark_latency_optimized(img_paths, yolo_shoe, yolo_micro, tower, mlp_model, reference_bank)"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"4ei9XBlFniRs","executionInfo":{"status":"ok","timestamp":1774299306232,"user_tz":300,"elapsed":6270,"user":{"displayName":"Kevin Osei-Onomah","userId":"07800293995269467633"}},"outputId":"bb777da4-9678-4d49-f250-2458063b4925"},"execution_count":4,"outputs":[{"output_type":"stream","name":"stdout","text":["\n","[Benchmarking OPTIMIZED Latency on 100 images]\n","Average Latency: 54.41 ms per image\n","95th Percentile: 64.68 ms per image\n","вљ пёЏ WARNING: Still exceeding 50ms. Further edge-optimization required.\n"]}]},{"cell_type":"code","source":["import pickle\n","import os\n","\n","# Assuming 'reference_bank' and 'CONFIG' are still in your notebook's memory\n","bank_path = os.path.join(CONFIG[\"BASE_DIR\"], \"reference_bank.pkl\")\n","\n","with open(bank_path, 'wb') as f:\n","    pickle.dump(reference_bank, f)\n","\n","print(f\"Reference bank saved successfully to: {bank_path}\")"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"zjdk1r1iO7Bg","executionInfo":{"status":"ok","timestamp":1774299306253,"user_tz":300,"elapsed":17,"user":{"displayName":"Kevin Osei-Onomah","userId":"07800293995269467633"}},"outputId":"fc2d54a8-2d86-4568-f82e-c43e5ad6a2ab"},"execution_count":5,"outputs":[{"output_type":"stream","name":"stdout","text":["Reference bank saved successfully to: /content/drive/MyDrive/Datasets/reference_bank.pkl\n"]}]}],"metadata":{"colab":{"provenance":[],"machine_shape":"hm","gpuType":"T4","authorship_tag":"ABX9TyPC0DLNPPHyZ+VKinhu/0Mw"},"kernelspec":{"display_name":"Python 3","name":"python3"},"language_info":{"name":"python"},"accelerator":"GPU"},"nbformat":4,"nbformat_minor":0}